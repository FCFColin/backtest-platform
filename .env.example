# =============================================================================
# 回测平台 - 环境变量示例
#
# 使用方法：复制本文件为 .env 并根据实际环境修改
#   cp .env.example .env
#
# 所有配置项均有开发环境友好的默认值，未设置时使用默认值即可启动。
# 生产环境部署时请务必覆盖带 [生产必填] 标记的变量。
# =============================================================================

# -----------------------------------------------------------------------------
# 运行环境
# -----------------------------------------------------------------------------
# 应用运行环境：development | production | test
# - development（默认）：错误详情会返回客户端，便于调试
# - production：隐藏错误详情，需设置 ADMIN_API_KEY
# - test：测试环境
NODE_ENV=development

# -----------------------------------------------------------------------------
# API 服务
# -----------------------------------------------------------------------------
# 后端 API 监听端口
# 兼容旧变量 PORT（API_PORT 优先级更高）
API_PORT=5001

# -----------------------------------------------------------------------------
# Go 引擎（主回测引擎，ADR-008）
# -----------------------------------------------------------------------------
# Go 引擎服务地址，替代 Rust 引擎作为主回测引擎
# 不可用时自动回退到 Rust 引擎，最终降级到 Node.js 备用引擎
# 复用 Rust 引擎同一端口 5002，渐进式迁移确保零停机
GO_ENGINE_URL=http://127.0.0.1:5002

# -----------------------------------------------------------------------------
# Rust 引擎（废弃中，ADR-008）
# -----------------------------------------------------------------------------
# [废弃] Rust 引擎服务地址，已被 Go 引擎替代（GO_ENGINE_URL）
# 保留作为二级回退，迁移完成后将移除此配置项
# 不可用时自动降级到 Node.js 备用引擎
RUST_ENGINE_URL=http://127.0.0.1:5002
# 引擎调用超时时间（毫秒），超时后降级到 Node.js 引擎
# 同时适用于 Go 引擎和 Rust 引擎
RUST_ENGINE_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# Go 数据服务（主数据源）
# -----------------------------------------------------------------------------
# Go 数据服务地址，不可用时降级到 Python 子进程或本地 JSON 文件
GO_DATA_SERVICE_URL=http://127.0.0.1:5003

# Go 数据服务认证 token（X-Data-Service-Auth 请求头）
# 与 data-fetcher 服务的 DATA_SERVICE_AUTH_TOKEN 必须一致
# Production: use a strong random token (>= 32 chars)
DATA_SERVICE_AUTH_TOKEN=dev-data-service-auth-token

# -----------------------------------------------------------------------------
# Go 引擎认证 token（X-Engine-Auth 请求头）
# 与 engine-go 服务的 ENGINE_AUTH_TOKEN 必须一致
# Production: use a strong random token (>= 32 chars)
ENGINE_AUTH_TOKEN=dev-engine-auth-token

# -----------------------------------------------------------------------------
# 跨域配置
# -----------------------------------------------------------------------------
# 允许的 CORS 来源，多个来源用逗号分隔
# 留空或设为 "*" 表示允许所有来源（默认，开发友好）
# 生产环境建议限定来源，例如：
#   CORS_ORIGINS=http://localhost:5173,https://your-domain.com
CORS_ORIGINS=

# -----------------------------------------------------------------------------
# 管理后台
# -----------------------------------------------------------------------------
# 管理后台 API 密钥
# [生产必填] 当 NODE_ENV=production 时必需，否则启动校验失败
# 开发环境可留空
ADMIN_API_KEY=

# 是否强制要求 API Key 认证
# 设为 true 时，所有业务端点（包括 /api/backtest/*）强制要求 API Key
# 默认 false（可选认证：有 Key 验证身份，无 Key 放行）
# REQUIRE_API_KEY=false

# -----------------------------------------------------------------------------
# JWT 认证（T-P1-8）
# -----------------------------------------------------------------------------
# JWT 签名密钥
# [生产必填] 当 NODE_ENV=production 时必须修改默认值，否则启动校验失败
# 开发环境可留空（使用内置默认值，自动跳过认证）
# JWT_SECRET=

# JWT Access Token 有效期（秒）
# 默认 900（15 分钟），短期有效降低泄露风险
# JWT_ACCESS_TTL=900

# JWT Refresh Token 有效期（秒）
# 默认 604800（7 天），用于无感刷新 Access Token
JWT_REFRESH_TTL=604800

# -----------------------------------------------------------------------------
# PostgreSQL 数据库（ADR-007）
# -----------------------------------------------------------------------------
# 数据库连接 URL（PostgreSQL 16+）
# [生产必填] 当 NODE_ENV=production 时必须通过环境变量设置
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# Production: must use ?sslmode=require for TLS encryption
# 开发环境默认连接本地 PostgreSQL（需先启动 docker-compose 或本地 PG）
DATABASE_URL=postgresql://backtest:backtest@localhost:5432/backtest
