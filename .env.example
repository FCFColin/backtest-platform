# =============================================================================
# 回测平台 - 环境变量示例
#
# 使用方法：复制本文件为 .env 并根据实际环境修改
#   cp .env.example .env
#
# 所有配置项均有开发环境友好的默认值，未设置时使用默认值即可启动。
# 生产环境部署时请务必覆盖带 [生产必填] 标记的变量。
# =============================================================================

# -----------------------------------------------------------------------------
# 运行环境
# -----------------------------------------------------------------------------
# 应用运行环境：development | production | test
# - development（默认）：错误详情会返回客户端，便于调试
# - production：隐藏错误详情，需设置 ADMIN_API_KEY
# - test：测试环境
NODE_ENV=development

# SaaS 本地开发：由 scripts/dev.mjs 自动注入 SERVE_STATIC=true，API 托管 dist/（首屏秒开）
# 使用 Vite HMR 热更新时改用 npm run dev:hmr（5176 端口，首访较慢）
# SERVE_STATIC=true

# -----------------------------------------------------------------------------
# API 服务
# -----------------------------------------------------------------------------
# 后端 API 监听端口
# 兼容旧变量 PORT（API_PORT 优先级更高）
API_PORT=5001

# -----------------------------------------------------------------------------
# 废弃端点 Sunset（RFC 8594）
# -----------------------------------------------------------------------------
# Deprecated 端点（如 POST /logout、POST /api/v1/data/manage/*）响应的 Sunset 头日期。
# ISO 8601 格式（YYYY-MM-DD 或完整时间戳），如 2026-12-31。
# 必须为固定日期：服务重启不应使 Sunset 滚动后移，否则废弃端点永远不会自然到期。
# 未设置时回退到运行时滚动 6 个月（仅作向后兼容，会触发启动 deprecation 警告）。
DEPRECATED_SUNSET_DATE=2026-12-31

# -----------------------------------------------------------------------------
# Go 引擎（唯一回测引擎，ADR-008 / ADR-031）
# -----------------------------------------------------------------------------
# Go 引擎服务地址（端口 5004），平台唯一的回测/分析/优化/蒙特卡洛引擎。
# Rust 引擎已退役（Go↔Rust parity 验证通过后删除）。
# 不可用时按 fail-closed 策略返回 503 + Retry-After（ADR-031），不再静默降级到 Node。
# 本地启动：cd engine-go && go run ./cmd/server
GO_ENGINE_URL=http://127.0.0.1:5004

# 引擎调用超时时间（毫秒），超时计为熔断器一次失败。
# 兼容旧变量名 RUST_ENGINE_TIMEOUT_MS。
ENGINE_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# Go 数据服务（主数据源）
# -----------------------------------------------------------------------------
# Go 数据服务地址，不可用时降级到本地 JSON 文件（Python 数据引擎已退役，ADR-008）
GO_DATA_SERVICE_URL=http://127.0.0.1:5003

# Go 数据服务认证 token（X-Data-Service-Auth 请求头）
# 与 data-fetcher 服务的 DATA_SERVICE_AUTH_TOKEN 必须一致
# Production: use a strong random token (>= 32 chars)
DATA_SERVICE_AUTH_TOKEN=dev-data-service-auth-token

# -----------------------------------------------------------------------------
# Go 引擎认证 token（X-Engine-Auth 请求头）
# 与 engine-go 服务的 ENGINE_AUTH_TOKEN 必须一致
# Production: use a strong random token (>= 32 chars)
ENGINE_AUTH_TOKEN=dev-engine-auth-token

# -----------------------------------------------------------------------------
# 跨域配置
# -----------------------------------------------------------------------------
# 允许的 CORS 来源，多个来源用逗号分隔
# 留空或设为 "*" 表示允许所有来源（默认，开发友好）
# 生产环境建议限定来源，例如：
#   CORS_ORIGINS=http://localhost:5173,https://your-domain.com
CORS_ORIGINS=

# -----------------------------------------------------------------------------
# 管理后台
# -----------------------------------------------------------------------------
# 管理后台 API 密钥
# [生产必填] 当 NODE_ENV=production 时必需，否则启动校验失败
# 开发环境可留空
ADMIN_API_KEY=

# 是否强制要求 API Key 认证
# 设为 true 时，所有业务端点（包括 /api/backtest/*）强制要求 API Key
# 默认 false（可选认证：有 Key 验证身份，无 Key 放行）
# REQUIRE_API_KEY=false

# -----------------------------------------------------------------------------
# JWT 认证（T-P1-8）
# -----------------------------------------------------------------------------
# JWT 签名密钥
# [生产必填] 当 NODE_ENV=production 时必须修改默认值，否则启动校验失败
# 开发环境可留空（使用内置默认值，自动跳过认证）
# JWT_SECRET=

# JWT Access Token 有效期（秒）
# 默认 900（15 分钟），短期有效降低泄露风险
# JWT_ACCESS_TTL=900

# JWT Refresh Token 有效期（秒）
# 默认 604800（7 天），用于无感刷新 Access Token
JWT_REFRESH_TTL=604800

# -----------------------------------------------------------------------------
# PostgreSQL 数据库（ADR-007）
# -----------------------------------------------------------------------------
# 数据库连接 URL（PostgreSQL 16+）
# [生产必填] 当 NODE_ENV=production 时必须通过环境变量设置
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# Production: must use ?sslmode=require for TLS encryption
# 开发环境默认连接本地 PostgreSQL（需先启动 docker-compose 或本地 PG）
# T-21b：应用运行期使用最小权限角色 backtest_app（DDL 由迁移账户执行）
DATABASE_URL=postgresql://backtest_app:backtest_app_dev@localhost:5432/backtest
# 连接池最大连接数（默认 20）
# DB_POOL_MAX=20
# 连接池最小空闲连接数（默认 2）
# DB_POOL_MIN=2
# 迁移/初始化专用（仅本地执行 migrations 时使用，勿用于应用运行时）
# MIGRATION_DATABASE_URL=postgresql://backtest:backtest@localhost:5432/backtest

# T-32：开发环境显式跳过 JWT（仅 development + true）
DEV_SKIP_AUTH=false

# T-29：调试端点 Bearer 令牌（未设置则 /api/v1/debug/* 返回 404）
DEBUG_AUTH_TOKEN=

# 运维端点 Bearer 令牌（/ready / /metrics）
# 未设置时允许匿名访问（开发/内网场景）；生产环境建议设置
METRICS_AUTH_TOKEN=

# 审计日志与缓存完整性校验 HMAC 密钥
# [生产必填] 长度 >= 32，用于审计日志签名与缓存文件完整性校验
AUDIT_HMAC_KEY=

# T-19：同步回测超时（毫秒）
BACKTEST_SYNC_TIMEOUT_MS=120000

# 同步计算端点超时（毫秒），BullMQ 不可用回退同步执行时生效
# 默认 30000（30 秒）
SYNC_COMPUTE_TIMEOUT_MS=30000

# 反向代理跳数（Express trust proxy，用于正确识别客户端 IP 以限流）
# [生产必填] 部署在 LB/Ingress 后设为代理层数（通常 1）；API 可被客户端直连时设为 0
# TRUST_PROXY_HOPS=1

# -----------------------------------------------------------------------------
# 应用基址（ADR-035）：用于注册验证 / 邀请 / 计费跳转链接拼接
# -----------------------------------------------------------------------------
APP_BASE_URL=http://localhost:5176

# -----------------------------------------------------------------------------
# 邮件发送（ADR-035，自助注册 / 组织邀请）
# -----------------------------------------------------------------------------
# 传输方式：console（默认，开发环境仅把链接打印到日志，不实际发信）| smtp（生产）
EMAIL_TRANSPORT=console
# 发件人地址
EMAIL_FROM="Backtest Platform <no-reply@backtest.platform>"
# SMTP 配置（EMAIL_TRANSPORT=smtp 时 EMAIL_SMTP_HOST 必填）
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=

# -----------------------------------------------------------------------------
# Stripe 计费（ADR-036）：留空则计费端点返回 503（计费未启用），不影响其余功能
# -----------------------------------------------------------------------------
# 使用 test-mode 密钥（sk_test_... / pk_test_... / whsec_...）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
# 各付费计划对应的 Stripe Price ID（price_...）
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# -----------------------------------------------------------------------------
# OpenTelemetry 链路追踪（OTLP 导出端点）
# -----------------------------------------------------------------------------
# OTLP traces 导出端点（Jaeger / Tempo / OTel Collector）
# 未设置时使用 stdout exporter（零依赖），生产环境可指向 collector
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# OTLP metrics 独立导出端点（与 traces 解耦，Jaeger 不接收 metrics）
# 未设置时使用 prom-client 拉取模型（/metrics 端点）
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://otel-collector:4318
