{
  "name": "@backtest/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "server:dev": "tsx src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --format=esm --outdir=dist",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@backtest/shared": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/instrumentation-pg": "^0.72.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.46.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.0",
    "jose": "^5.10.0",
    "nodemailer": "^6.10.0",
    "opossum": "^8.5.0",
    "pg": "^8.14.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.0",
    "rate-limit-redis": "^4.2.0",
    "stripe": "^17.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.15.30",
    "@types/nodemailer": "^8.0.1",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.20.0",
    "esbuild": "^0.28.1",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.1"
  }
}
