{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@backtest/shared": ["./packages/shared/types/index.ts"],
      "@backtest/shared/types": ["./packages/shared/types/index.ts"],
      "@backtest/shared/types/*": ["./packages/shared/types/*"],
      "@backtest/shared/*": ["./packages/shared/*"]
    }
  }
}
