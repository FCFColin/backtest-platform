{
  "name": "backtest-platform",
  "private": true,
  "version": "0.2.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:hmr": "concurrently \"pnpm --filter @backtest/frontend dev\" \"pnpm --filter @backtest/backend dev\"",
    "build": "pnpm --filter @backtest/frontend build",
    "depcheck": "depcruise --config .dependency-cruiser.config.mjs api/ src/",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:frontend": "tsc --noEmit -p tsconfig.frontend.json",
    "check:backend": "tsc --noEmit -p tsconfig.backend.json",
    "check": "pnpm run check:frontend && pnpm run check:backend",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:unit:frontend": "vitest run -c vitest.config.frontend.ts",
    "test:unit:backend": "vitest run -c vitest.config.backend.ts",
    "test:unit:shared": "vitest run -c vitest.config.shared.ts",
    "test:chaos": "vitest run -c vitest.config.chaos.ts",
    "test:integration": "vitest run tests/integration",
    "test:consistency": "vitest run tests/consistency",
    "test:contract": "vitest run tests/contract",
    "test:fuzz": "vitest run tests/fuzz",
    "test:e2e:ui": "playwright test",
    "test:e2e:backtest": "playwright test tests/e2e/ui/backtest",
    "test:e2e:ui:headed": "playwright test --headed",
    "test:e2e:ui:coverage": "playwright test && npx nyc report --reporter=html --reporter=text --report-dir=coverage/playwright",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:check": "vitest run --coverage && node scripts/check-coverage.mjs",
    "test:property": "vitest run tests/property",
    "test:bench": "vitest bench",
    "simplify": "echo 'jscpd not installed. Install with: npm install -g jscpd'",
    "deadcode": "knip --no-exit-code",
    "audit:supply": "pnpm audit --audit-level=high --prod",
    "profile:flame": "npx --yes clinic flame -- node --import tsx api/server.ts",
    "profile:doctor": "npx --yes clinic doctor -- node --import tsx api/server.ts",
    "license:check": "license-checker --production --summary --onlyAllow 'MIT;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;0BSD;CC0-1.0;Unlicense;Python-2.0;BlueOak-1.0.0' || true",
    "import:market-data": "tsx -e \"import { importAllMarketData } from './api/db/import.js'; importAllMarketData().then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); })\"",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@backtest/shared": "workspace:*",
    "@eslint/js": "^9.25.0",
    "@opentelemetry/api": "^1.9.0",
    "@playwright/test": "^1.61.0",
    "@testcontainers/postgresql": "^12.0.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vercel/node": "^5.1.14",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "argon2": "^0.41.1",
    "bullmq": "^5.46.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.0",
    "concurrently": "^9.2.0",
    "cors": "^2.8.5",
    "dependency-cruiser": "^18.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-sonarjs": "^3.0.1",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.0",
    "fast-check": "^4.8.0",
    "globals": "^16.0.0",
    "happy-dom": "^17.4.4",
    "helmet": "^8.0.0",
    "husky": "^9.0.11",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "ioredis": "^5.6.0",
    "jose": "^5.10.0",
    "knip": "^5.46.0",
    "lint-staged": "^17.0.8",
    "lucide-react": "^0.511.0",
    "nodemailer": "^6.10.0",
    "nyc": "^18.0.0",
    "opossum": "^8.5.0",
    "pg": "^8.14.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prettier": "^3.9.1",
    "prom-client": "^15.1.0",
    "rate-limit-redis": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.7.4",
    "react-router-dom": "^6.30.4",
    "recharts": "^2.15.4",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.6.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.4.3",
    "vite-plugin-istanbul": "^7.2.1",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.0",
    "wait-on": "^9.0.10",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "nyc": {
    "temp-dir": ".nyc_output",
    "report-dir": "coverage/playwright",
    "include": [
      "src/**/*.{ts,tsx}"
    ],
    "exclude": [
      "src/**/*.d.ts",
      "src/i18n/**",
      "tests/**"
    ]
  }
}
