{
  "name": "backtest-platform",
  "private": true,
  "version": "0.2.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "client:build": "vite build",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "check:frontend": "tsc --noEmit -p tsconfig.frontend.json",
    "check:backend": "tsc --noEmit -p tsconfig.backend.json",
    "check": "npm run check:frontend && npm run check:backend",
    "server:dev": "nodemon",
    "dev": "node scripts/dev.mjs",
    "dev:hmr": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:chaos": "vitest run -c vitest.config.chaos.ts",
    "test:integration": "vitest run tests/integration",
    "test:consistency": "vitest run tests/consistency",
    "test:contract": "vitest run tests/contract",
    "test:fuzz": "vitest run tests/fuzz",
    "test:e2e:ui": "playwright test",
    "test:e2e:backtest": "playwright test tests/e2e/ui/backtest",
    "test:e2e:ui:headed": "playwright test --headed",
    "test:e2e:ui:coverage": "playwright test && npx nyc report --reporter=html --reporter=text --report-dir=coverage/playwright",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:check": "vitest run --coverage && node scripts/check-coverage.mjs",
    "test:bench": "vitest bench",
    "simplify": "echo 'jscpd not installed. Install with: npm install -g jscpd'",
    "deadcode": "knip --no-exit-code",
    "audit:supply": "npm audit --audit-level=high --omit=dev",
    "profile:flame": "npx --yes clinic flame -- node --import tsx api/server.ts",
    "profile:doctor": "npx --yes clinic doctor -- node --import tsx api/server.ts",
    "license:check": "license-checker --production --summary --onlyAllow 'MIT;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;0BSD;CC0-1.0;Unlicense;Python-2.0;BlueOak-1.0.0' || true",
    "import:market-data": "tsx -e \"import { importAllMarketData } from './api/db/import.js'; importAllMarketData().then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); })\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.219.0",
    "@opentelemetry/instrumentation-pg": "^0.71.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.79.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "lucide-react": "^0.511.0",
    "nodemailer": "^9.0.1",
    "opossum": "^9.0.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.3.0",
    "recharts": "^2.15.0",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.0.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.61.0",
    "@testcontainers/postgresql": "^12.0.3",
    "@testing-library/react": "^16.3.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@types/nodemailer": "^8.0.1",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-sonarjs": "^3.0.1",
    "globals": "^16.0.0",
    "happy-dom": "^20.10.6",
    "knip": "^5.46.0",
    "@vercel/node": "^5.1.14",
    "husky": "^9.0.11",
    "lint-staged": "^17.0.8",
    "nodemon": "^3.1.10",
    "nyc": "^18.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.9.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-istanbul": "^6.0.2",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.0",
    "wait-on": "^9.0.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "nyc": {
    "temp-dir": ".nyc_output",
    "report-dir": "coverage/playwright",
    "include": [
      "src/**/*.{ts,tsx}"
    ],
    "exclude": [
      "src/**/*.d.ts",
      "src/i18n/**",
      "tests/**"
    ]
  }
}
