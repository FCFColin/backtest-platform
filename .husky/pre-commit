# Security: gitleaks密钥扫描（T-7：未安装则失败，非跳过）
if ! command -v gitleaks &> /dev/null; then
  echo "ERROR: gitleaks not installed. Install from https://github.com/gitleaks/gitleaks"
  exit 1
fi
gitleaks protect --source . --no-banner || { echo "ERROR: Potential secrets detected by gitleaks"; exit 1; }

npx lint-staged
